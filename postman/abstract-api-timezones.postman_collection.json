        {
          "name": "Abstract API Get Current Time",
          "id": "9f9d3b44-10af-42d7-94ab-5337bd2e43d8",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/current_time?api_key=<string>&location=<string>&latitude=<double>&longitude=<double>&ip_address=<string>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "current_time"
              ],
              "query": [
                {
                  "description": "(Required) Your unique API key for the Timezone API.",
                  "key": "api_key",
                  "value": "<string>"
                },
                {
                  "description": "Location name (e.g., city, address). Use location, latitude+longitude, or ip_address.",
                  "key": "location",
                  "value": "<string>"
                },
                {
                  "description": "Latitude coordinate. Used with longitude.",
                  "key": "latitude",
                  "value": "<double>"
                },
                {
                  "description": "Longitude coordinate. Used with latitude.",
                  "key": "longitude",
                  "value": "<double>"
                },
                {
                  "description": "IP address to determine timezone from.",
                  "key": "ip_address",
                  "value": "<string>"
                }
              ]
            },
            "description": "Get the current time, date, and timezone for a location specified by name, coordinates, or IP address."
