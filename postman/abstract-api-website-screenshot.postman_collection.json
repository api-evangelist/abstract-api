                "key": "Accept",
                "value": "image/jpeg"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/?api_key=<string>&url=<uri>&capture_full_page=<boolean>&width=<integer>&height=<integer>&delay=<integer>&css_injection=<string>&export_format=png",
