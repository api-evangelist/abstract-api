{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CurrencyInfo",
  "title": "CurrencyInfo",
  "type": "object",
  "properties": {
    "currency_name": {
      "type": "string",
      "description": "Currency full name",
      "example": "US Dollar"
    },
    "currency_code": {
      "type": "string",
      "description": "ISO 4217 currency code",
      "example": "USD"
    }
  }
}